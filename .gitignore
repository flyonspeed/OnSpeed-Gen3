.DS_Store
Software/.DS_Store
Software/Arduino/.DS_Store
Software/Arduino/libraries/.DS_Store
software/OnSpeed-Gen3-ESP32/OnSpeed_Gen3-ESP32.vcxproj
software/OnSpeed-Gen3-ESP32/OnSpeed_Gen3-ESP32.sln
software/OnSpeed-Gen3-ESP32/OnSpeed_Gen3-ESP32.vcxproj.user
software/OnSpeed-Gen3-ESP32/OnSpeed_Gen3-ESP32.vcxproj.filters
.pio

# M5 display WASM build output (Emscripten; regenerate via ./sim/build_wasm.sh)
software/OnSpeed-M5-Display/sim/build/

# M5 display logo intermediate renders (regenerate via scripts/gen_logo_header.py)
software/OnSpeed-M5-Display/.logo-build/

# M5 display sim copied into the docs site by CI (or locally by
# ./scripts/build_m5_sim_for_docs.sh); committed copies would drift.
docs/site/docs/assets/sim/

# auto-generated on each build by PlatformIO / Arduino IDE
software/Libraries/version/buildinfo.cpp
lib/version/buildinfo.cpp
*.ino.cpp

# Web bundle: generated from tools/web/ by scripts/build_web_bundle.py.
# PlatformIO regenerates these as a pre-build hook.  Arduino IDE users
# must run `python3 scripts/build_web_bundle.py` once after clone (and
# again after editing tools/web/).
software/OnSpeed-Gen3-ESP32/Web/static_app_js.h
software/OnSpeed-Gen3-ESP32/Web/static_app_css.h
software/OnSpeed-Gen3-ESP32/Web/html_stubs.h
software/OnSpeed-Gen3-ESP32/Web/legacy_pages.h
software/OnSpeed-Gen3-ESP32/Web/legacy_pages.cpp

# git worktrees for parallel subagent work
.worktrees/

# clangd compile database — machine-local absolute paths, regenerate with
# `pio run -t compiledb -e <env>`. See .clangd for usage notes.
compile_commands.json

# Coverage artifacts (produced by scripts/coverage.sh and CI)
coverage.info
coverage-report/
*.gcda
*.gcno

# Editor / merge backup files — never want these in git
*.orig
*.bak
*.swp
*~